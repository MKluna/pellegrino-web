---
// Smooth scroll using Lenis. Survives Astro View Transitions.
---
<script>
  import Lenis from 'lenis';

  // Hold a single instance across page navigations
  declare global {
    interface Window {
      __lenis?: import('lenis').default;
      __lenisRAF?: number;
    }
  }

  function initLenis() {
    // If already running, do nothing
    if (window.__lenis) return;

    const lenis = new Lenis({
      duration: 1.15,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel: true,
      wheelMultiplier: 1,
      touchMultiplier: 1.4,
    });

    window.__lenis = lenis;

    function raf(time: number) {
      lenis.raf(time);
      window.__lenisRAF = requestAnimationFrame(raf);
    }
    window.__lenisRAF = requestAnimationFrame(raf);

    // Anchor links inside the page should use Lenis scrollTo
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const link = target.closest('a[href^="#"]') as HTMLAnchorElement | null;
      if (!link) return;
      const id = link.getAttribute('href');
      if (!id || id === '#') return;
      const el = document.querySelector(id);
      if (!el) return;
      e.preventDefault();
      lenis.scrollTo(el as HTMLElement, { offset: -80 });
    });
  }

  function destroyLenis() {
    if (window.__lenisRAF) cancelAnimationFrame(window.__lenisRAF);
    window.__lenis?.destroy();
    window.__lenis = undefined;
    window.__lenisRAF = undefined;
  }

  // Run on first load
  initLenis();

  // Re-init after Astro View Transition navigation:
  // destroy old instance, then init fresh on the new DOM.
  document.addEventListener('astro:before-swap', destroyLenis);
  document.addEventListener('astro:page-load', initLenis);
</script>
