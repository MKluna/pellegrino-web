---
import CartIcon from '../cart/CartIcon';
import { CATEGORIES } from '../../data/products';

const LABELS: Record<string, string> = {
  BOLSOS: 'Bolsos',
  BILLETERAS: 'Billeteras',
  CARTERAS: 'Carteras',
  MOCHILAS: 'Mochilas',
  PORTAFOLIOS: 'Portafolios',
  'RIÑONERAS': 'Riñoneras',
};
---
<header class="fixed top-0 left-0 right-0 z-50 bg-obsidian/95 backdrop-blur-sm border-b border-smoke">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      aria-label="Abrir menú"
      class="md:hidden p-2 -ml-2 text-parchment hover:text-gold transition-colors duration-200"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>

    <a href="/" class="font-serif text-xl text-cream tracking-[0.25em] uppercase hover:text-gold transition-colors duration-200">
      PELLEGRINO
    </a>

    <nav class="hidden md:flex items-center gap-10 text-xs text-parchment tracking-[0.2em] uppercase">
      <a href="/" class="hover:text-gold transition-colors duration-200">Inicio</a>
      <a href="/catalogo" class="hover:text-gold transition-colors duration-200">Catálogo</a>
    </nav>

    <div class="flex items-center gap-4">
      <CartIcon client:load />
    </div>
  </div>
</header>

<!-- Mobile drawer -->
<div
  id="menu-overlay"
  class="fixed inset-0 z-40 bg-obsidian/70 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300"
></div>

<aside
  id="menu-drawer"
  class="fixed top-0 left-0 z-50 h-screen w-full max-w-[320px] bg-charcoal border-r border-smoke -translate-x-full transition-transform duration-350 ease-out flex flex-col"
  aria-hidden="true"
>
  <!-- Header -->
  <div class="flex items-center justify-between px-6 py-5 border-b border-smoke">
    <span class="font-serif text-lg text-cream tracking-[0.2em]">MENÚ</span>
    <button
      id="menu-close"
      aria-label="Cerrar menú"
      class="text-parchment hover:text-gold transition-colors duration-200 p-1"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Links -->
  <div data-lenis-prevent class="flex-1 overflow-y-auto px-6 py-8">
    <nav class="space-y-6">
      <div>
        <p class="text-xs text-gold tracking-[0.25em] uppercase mb-3">Navegación</p>
        <ul class="space-y-3">
          <li>
            <a href="/" class="block font-serif text-2xl text-cream hover:text-gold transition-colors duration-200">
              Inicio
            </a>
          </li>
          <li>
            <a href="/catalogo" class="block font-serif text-2xl text-cream hover:text-gold transition-colors duration-200">
              Catálogo
            </a>
          </li>
        </ul>
      </div>

      <div class="pt-4 border-t border-smoke">
        <p class="text-xs text-gold tracking-[0.25em] uppercase mb-3">Categorías</p>
        <ul class="space-y-2">
          {CATEGORIES.map((cat) => (
            <li>
              <a
                href={`/catalogo?categoria=${encodeURIComponent(cat)}`}
                class="block text-sm text-parchment tracking-wide hover:text-gold transition-colors duration-200 py-1"
              >
                {LABELS[cat] ?? cat}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  </div>

  <!-- Footer -->
  <div class="px-6 py-5 border-t border-smoke">
    <a
      href="https://wa.me/543834694676"
      target="_blank"
      rel="noopener"
      class="flex items-center justify-center gap-2 w-full py-3 border border-gold text-gold text-xs tracking-[0.2em] uppercase hover:bg-gold hover:text-obsidian transition-all duration-200"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Contactar
    </a>
  </div>
</aside>

<script>
  function setupMenu() {
    const toggle = document.getElementById('menu-toggle');
    const close = document.getElementById('menu-close');
    const drawer = document.getElementById('menu-drawer');
    const overlay = document.getElementById('menu-overlay');

    if (!toggle || !close || !drawer || !overlay) return;

    function open() {
      drawer!.classList.remove('-translate-x-full');
      drawer!.setAttribute('aria-hidden', 'false');
      overlay!.classList.remove('opacity-0', 'pointer-events-none');
      document.body.style.overflow = 'hidden';
    }

    function shut() {
      drawer!.classList.add('-translate-x-full');
      drawer!.setAttribute('aria-hidden', 'true');
      overlay!.classList.add('opacity-0', 'pointer-events-none');
      document.body.style.overflow = '';
    }

    toggle.addEventListener('click', open);
    close.addEventListener('click', shut);
    overlay.addEventListener('click', shut);

    // Close on link click (so navigation feels natural)
    drawer.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', shut);
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') shut();
    });
  }

  setupMenu();
  document.addEventListener('astro:page-load', setupMenu);
</script>
