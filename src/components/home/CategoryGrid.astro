---
import { Image } from 'astro:assets';
import { CATEGORIES, CATEGORY_IMAGES } from '../../data/products';
import ScrollReveal from '../ui/ScrollReveal.astro';

const LABELS: Record<string, string> = {
  BOLSOS: 'Bolsos',
  BILLETERAS: 'Billeteras',
  CARTERAS: 'Carteras',
  MOCHILAS: 'Mochilas',
  PORTAFOLIOS: 'Portafolios',
  'RIÑONERAS': 'Riñoneras',
};
---
<section class="py-20 px-6">
  <div class="max-w-7xl mx-auto">
    <ScrollReveal class="text-center mb-12">
      <p class="text-gold text-xs tracking-[0.3em] uppercase mb-3">Explorar</p>
      <h2 class="font-serif text-4xl md:text-5xl text-cream font-light">Categorías</h2>
    </ScrollReveal>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {CATEGORIES.map((cat, i) => (
        <ScrollReveal delay={i * 80}>
          <a
            href={`/catalogo?categoria=${encodeURIComponent(cat)}`}
            class="group relative overflow-hidden aspect-[4/5] block"
          >
            <Image
              src={CATEGORY_IMAGES[cat]}
              alt={LABELS[cat] ?? cat}
              width={600}
              height={750}
              widths={[300, 600]}
              sizes="(max-width: 640px) 50vw, 33vw"
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-obsidian/50 group-hover:bg-obsidian/35 transition-colors duration-300"></div>
            <div class="absolute inset-0 border border-transparent group-hover:border-gold/60 transition-colors duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5">
              <p class="font-serif text-xl text-cream tracking-wide">{LABELS[cat] ?? cat}</p>
              <p class="text-gold text-xs tracking-widest mt-1 opacity-0 group-hover:opacity-100 transition-opacity duration-300 uppercase">
                Ver colección →
              </p>
            </div>
          </a>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
